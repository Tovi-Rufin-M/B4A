	items.Clear
	items.AddAll(Array As String("mm²","cm²","m²","km²","in²","ft²","yd²"))
	setspinner(items, Colors.ARGB(64, 255, 255, 255))
End Sub

Sub qick
	Dim spin As String = Spinner1.SelectedItem
	Dim choice As String = lblTitle.Text
	Dim firstinput As Double
	If EditText1.Text = "" Then
		firstinput = 0
	Else
		firstinput = EditText1.Text
	End If
	Dim result As String
	Dim parts() As String = Regex.Split(" to ", spin)
	Dim fromUnit As String = parts(0)
	Dim toUnit As String = parts(1)
	Dim ans As Double

	Select choice
		Case "Length Converter"
			Dim toMeter As Map
			toMeter.Initialize
			toMeter.Put("mm", 0.001)
			toMeter.Put("cm", 0.01)
			toMeter.Put("m", 1)
			toMeter.Put("km", 1000)
			toMeter.Put("in", 0.0254)
			toMeter.Put("ft", 0.3048)
			toMeter.Put("yd", 0.9144)
			toMeter.Put("mi", 1609.344)
			toMeter.Put("µm", 0.000001)
			ans = firstinput * toMeter.Get(fromUnit) / toMeter.Get(toUnit)
			result = NumberFormat(ans, 1, 4) & " " & toUnit

		Case "Weight Converter"
			Dim toGram As Map
			toGram.Initialize
			toGram.Put("µg", 0.000001)
			toGram.Put("mg", 0.001)
			toGram.Put("g", 1)
			toGram.Put("kg", 1000)
			toGram.Put("t", 1000000)
			toGram.Put("oz", 28.3495)
			toGram.Put("lb", 453.592)
			toGram.Put("st", 6350.29)
			toGram.Put("ct", 0.2)
			toGram.Put("ton", 907185)
			ans = firstinput * toGram.Get(fromUnit) / toGram.Get(toUnit)
			result = NumberFormat(ans, 1, 4) & " " & toUnit

		Case "Volume Converter"
			Dim toML As Map
			toML.Initialize
			toML.Put("mL", 1)
			toML.Put("L", 1000)
			toML.Put("kL", 1000000)
			toML.Put("cm³", 1)
			toML.Put("m³", 1000000)
			toML.Put("in³", 16.3871)
			toML.Put("ft³", 28316.8)
			ans = firstinput * toML.Get(fromUnit) / toML.Get(toUnit)
			result = NumberFormat(ans, 1, 4) & " " & toUnit

		Case "Speed Converter"
			Dim toMS As Map
			toMS.Initialize
			toMS.Put("m/s", 1)
			toMS.Put("km/h", 0.277778)
			toMS.Put("mph", 0.44704)
			toMS.Put("knot", 0.514444)
			toMS.Put("ft/s", 0.3048)
			ans = firstinput * toMS.Get(fromUnit) / toMS.Get(toUnit)
			result = NumberFormat(ans, 1, 4) & " " & toUnit

		Case "Temperature Converter"
			Dim celsius As Double
			Select fromUnit
				Case "°C" : celsius = firstinput
				Case "°F" : celsius = (firstinput - 32) / 1.8
				Case "K"  : celsius = firstinput - 273.15
				Case "°R" : celsius = (firstinput - 491.67) / 1.8
			End Select
			Select toUnit
				Case "°C" : ans = celsius
				Case "°F" : ans = (celsius * 1.8) + 32
				Case "K"  : ans = celsius + 273.15
				Case "°R" : ans = (celsius + 273.15) * 1.8
			End Select
			result = NumberFormat(ans, 1, 4) & " " & toUnit
			
		Case "Area Converter"
			Dim toM2 As Map
			toM2.Initialize
			toM2.Put("mm²", 0.000001)
			toM2.Put("cm²", 0.0001)
			toM2.Put("m²", 1)
			toM2.Put("km²", 1000000)
			toM2.Put("in²", 0.00064516)
			toM2.Put("ft²", 0.092903)
			toM2.Put("yd²", 0.836127)
			ans = firstinput * toM2.Get(fromUnit) / toM2.Get(toUnit)
			result = NumberFormat(ans, 1, 4) & " " & toUnit
			
		Case Else
			result = "0"
	End Select
	
	Label3.Text = result
End Sub

Sub convert
	Dim fromUnit, toUnit As String
	Dim result As String
	Dim ans As Double
	Dim input As Double 
	Dim choice As String = lblTitle.Text
	
	If EditText2.Text = "" Then
		input = 0
	Else
		input = EditText2.Text
	End If
	
	fromUnit = Spinner2.SelectedItem
	toUnit = Spinner3.SelectedItem

	Select choice
		Case "Length Converter"
			Dim toMeter As Map
			toMeter.Initialize
			toMeter.Put("mm", 0.001)      : toMeter.Put("cm", 0.01)
			toMeter.Put("m", 1)           : toMeter.Put("km", 1000)
			toMeter.Put("in", 0.0254)     : toMeter.Put("ft", 0.3048)
			toMeter.Put("yd", 0.9144)     : toMeter.Put("mi", 1609.344)
			toMeter.Put("µm", 0.000001)
			ans = input * toMeter.Get(fromUnit) / toMeter.Get(toUnit)
			
		Case "Weight Converter"
			Dim toGram As Map
			toGram.Initialize
			toGram.Put("µg", 0.000001)    : toGram.Put("mg", 0.001)
			toGram.Put("g", 1)            : toGram.Put("kg", 1000)
			toGram.Put("t", 1000000)      : toGram.Put("oz", 28.3495)
			toGram.Put("lb", 453.592)     : toGram.Put("st", 6350.29)
			toGram.Put("ct", 0.2)         : toGram.Put("ton", 907185)
			ans = input * toGram.Get(fromUnit) / toGram.Get(toUnit)
			
		Case "Volume Converter"
			Dim toML As Map
			toML.Initialize
			toML.Put("mL", 1)             : toML.Put("L", 1000)
			toML.Put("kL", 1000000)       : toML.Put("cm³", 1)
			toML.Put("m³", 1000000)       : toML.Put("in³", 16.3871)
			toML.Put("ft³", 28316.8)
			ans = input * toML.Get(fromUnit) / toML.Get(toUnit)
			
		Case "Speed Converter"
			Dim toMS As Map
			toMS.Initialize
			toMS.Put("m/s", 1)            : toMS.Put("km/h", 0.277778)
			toMS.Put("mph", 0.44704)      : toMS.Put("knot", 0.514444)
			toMS.Put("ft/s", 0.3048)
			ans = input * toMS.Get(fromUnit) / toMS.Get(toUnit)
			
		Case "Temperature Converter"
			Dim celsius As Double
			Select fromUnit
				Case "°C" : celsius = input
				Case "°F" : celsius = (input - 32) / 1.8
				Case "K"  : celsius = input - 273.15
				Case "°R" : celsius = (input - 491.67) / 1.8
			End Select
			Select toUnit
				Case "°C" : ans = celsius
				Case "°F" : ans = (celsius * 1.8) + 32
				Case "K"  : ans = celsius + 273.15
				Case "°R" : ans = (celsius + 273.15) * 1.8
			End Select
			
		Case "Area Converter"
			Dim toM2 As Map
			toM2.Initialize
			toM2.Put("mm²", 0.000001)     : toM2.Put("cm²", 0.0001)
			toM2.Put("m²", 1)             : toM2.Put("km²", 1000000)
			toM2.Put("in²", 0.00064516)   : toM2.Put("ft²", 0.092903)
			toM2.Put("yd²", 0.836127)
			ans = input * toM2.Get(fromUnit) / toM2.Get(toUnit)
			
		Case Else
			ans = 0
	End Select
	
	result = NumberFormat(ans, 1, 4) & " " & toUnit
	Label6.Text = result
End Sub

Sub Activity_KeyPress (KeyCode As Int) As Boolean
	If KeyCode = KeyCodes.KEYCODE_BACK And Drawer.LeftOpen Then
		Drawer.LeftOpen = False
		Return True
	Else If KeyCode = KeyCodes.KEYCODE_BACK And Not(Drawer.LeftOpen) Then
		Drawer.LeftOpen = True
		Return True
	End If
	
	Return False
End Sub

Private Sub Spinner3_ItemClick (Position As Int, Value As Object)
	convert
End Sub

Private Sub Spinner2_ItemClick (Position As Int, Value As Object)
	convert
End Sub

Private Sub Spinner1_ItemClick (Position As Int, Value As Object)
	qick
End Sub

Private Sub EditText2_EnterPressed
	convert
End Sub

Private Sub EditText1_EnterPressed
	qick
End Sub