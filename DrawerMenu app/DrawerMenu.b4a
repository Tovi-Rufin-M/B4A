'--- Show Layout Subs ---

Sub ShowHome
	pnlMain.RemoveAllViews
	pnlMain.LoadLayout("home")
	lblTitle.Text = "Home"
End Sub

Sub setspinner(item As List, color As Object)
	Spinner2.AddAll(item)
	Spinner3.AddAll(item)
	For Each s As Spinner In Array(Spinner1, Spinner2, Spinner3)
		s.TextSize = 14
		Dim pairItems As List
		pairItems.Initialize
		For i = 0 To item.Size - 2
			pairItems.Add(item.Get(i) & " to " & item.Get(i+1))
		Next
		' Spinner1 gets the "X to Y" pairs
		Dim cd As ColorDrawable
		cd.Initialize(color, 10dip)
		s.Background = cd
	Next
	Spinner1.AddAll(pairItems)
End Sub

Sub ShowPage1
	pnlMain.RemoveAllViews
	pnlMain.LoadLayout("page1")
	lblTitle.Text = "Length Converter"
	
	items.Clear
	items.AddAll(Array As String("mm","cm","m","km","in","ft","yd","mi","µm"))
	setspinner(items, Colors.ARGB(64, 255, 255, 255))
End Sub

Sub ShowPage2
	pnlMain.RemoveAllViews
	pnlMain.LoadLayout("page2")
	lblTitle.Text = "Wight Converter"
	
	items.Clear
	items.AddAll(Array As String("mg","g","kg","t","oz","lb","st","ct","µg","ton"))
	setspinner(items, Colors.ARGB(64, 255, 255, 255))
End Sub

