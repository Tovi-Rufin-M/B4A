#Region  Project Attributes 
	#ApplicationLabel: Drawer Unit Converter App
	#VersionCode: 1
	#VersionName: 
	'SupportedOrientations possible values: unspecified, landscape or portrait.
	#SupportedOrientations: portrait
	#CanInstallToExternalStorage: False
#End Region

#Region  Activity Attributes 
	#FullScreen: False
	#IncludeTitle: False
#End Region

Sub Process_Globals
	'These global variables will be declared once when the application starts.
	'These variables can be accessed from all modules.
	Private xui As XUI
End Sub

Sub Globals
	'These global variables will be redeclared each time the activity is created.
	Private Drawer As B4XDrawer
	Private pnlMain As Panel
	Private pnlMenu As Panel

	'Private lblMenu As Label
	Private lblTitle As Label
	Private btnHome, btnPage1, btnPage2, btnPage3, btnPage4, btnPage5, btnPage6 As Button
	
	Private EditText1 As EditText
	Private Label1 As Label
	
	Private items As List
	Private Spinner1, Spinner2, Spinner3 As Spinner
	Private Label3 As Label
	Private Label6 As Label
	Private EditText2 As EditText
End Sub

 Sub Activity_Create(FirstTime As Boolean)
	Activity.LoadLayout("main")
	
	Drawer.Initialize(Me, "Drawer", Activity, 260dip)
	Drawer.CenterPanel.BringToFront
	Drawer.LeftPanel.BringToFront

	pnlMain = Drawer.CenterPanel
	pnlMenu = Drawer.LeftPanel
	
	SetGradient(pnlMenu, Colors.rgb(175, 71, 210), Colors.RGB(38, 53, 93))
	
	items.Initialize
	
	CreateMenu
	ShowHome
End Sub

' Add this Sub to your code
Sub SetGradient(Panel As Panel, Color1 As Int, Color2 As Int)
	Dim gd As GradientDrawable
	gd.Initialize("BR_TL", Array As Int(Color1, Color2))
	Panel.Background = gd
End Sub

Sub Activity_Resume

End Sub

Sub Activity_Pause (UserClosed As Boolean)

End Sub

Sub btnMenu_Click
	Drawer.LeftOpen = Not(Drawer.LeftOpen)
End Sub

Sub CreateMenu
	Dim btnHome, btnPage1, btnPage2 As Button
	btnHome.Initialize("btnHome")
	btnHome.Text = "Home"
	btnPage1.Initialize("btnPage1")
	btnPage1.Text = "Length Converter"
	btnPage2.Initialize("btnPage2")
	btnPage2.Text = "Weight Converter"
	btnPage3.Initialize("btnPage3")
	btnPage3.Text = "Volume Converter"
	btnPage4.Initialize("btnPage4")
	btnPage4.Text = "Speed Converter"
	btnPage5.Initialize("btnPage5")
	btnPage5.Text = "Temperature Converter"
	btnPage6.Initialize("btnPage6")
	btnPage6.Text = "Area Converter"
	
	For Each b As Button In Array(btnHome, btnPage1, btnPage2, btnPage3, btnPage4, btnPage5, btnPage6)
		b.TextSize = 16
		b.Gravity = Gravity.LEFT + Gravity.CENTER_VERTICAL
		b.Color = Colors.Transparent
		b.TextColor = Colors.White
		pnlMenu.AddView(b, 10dip, 0, 240dip, 50dip)
	Next
	btnHome.Top = 120dip
	btnPage1.Top = 180dip
	btnPage2.Top = 240dip
	btnPage3.Top = 300dip
	btnPage4.Top = 360dip
	btnPage5.Top = 420dip
	btnPage6.Top = 480dip
End Sub

